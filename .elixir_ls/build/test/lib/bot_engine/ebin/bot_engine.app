{application,bot_engine,
    [{compile_env,
         [{bot_engine,['Elixir.BotEngineWeb.Endpoint',code_reloader],error},
          {bot_engine,['Elixir.BotEngineWeb.Endpoint',debug_errors],error},
          {bot_engine,['Elixir.BotEngineWeb.Endpoint',force_ssl],error},
          {bot_engine,['Elixir.BotEngineWeb.Gettext'],error},
          {bot_engine,[dev_routes],error}]},
     {optional_applications,[]},
     {applications,
         [kernel,stdlib,elixir,logger,runtime_tools,phoenix,phoenix_ecto,
          ecto_sql,postgrex,phoenix_live_dashboard,telemetry_metrics,
          telemetry_poller,gettext,jason,dns_cluster,bandit,oban,req]},
     {description,"bot_engine"},
     {modules,
         ['Elixir.BotEngine','Elixir.BotEngine.Application',
          'Elixir.BotEngine.Chat','Elixir.BotEngine.Chat.Message',
          'Elixir.BotEngine.DataCase','Elixir.BotEngine.Repo',
          'Elixir.BotEngine.Webhooks.Worker','Elixir.BotEngineWeb',
          'Elixir.BotEngineWeb.BotSocket','Elixir.BotEngineWeb.ConnCase',
          'Elixir.BotEngineWeb.Endpoint','Elixir.BotEngineWeb.ErrorJSON',
          'Elixir.BotEngineWeb.Gettext','Elixir.BotEngineWeb.RoomChannel',
          'Elixir.BotEngineWeb.Router','Elixir.BotEngineWeb.Telemetry']},
     {registered,[]},
     {vsn,"0.1.0"},
     {mod,{'Elixir.BotEngine.Application',[]}}]}.
